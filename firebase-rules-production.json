{
  "rules": {
    ".read": false,
    ".write": false,

    "orders": {
      ".read": "auth != null",
      ".write": true
    },

    "order_lookup": {
      ".read": false,
      ".write": true,
      "$lookupKey": {
        ".read": true,
        ".write": true
      }
    },

    "order_counter": {
      ".read": true,
      ".write": true
    },

    "customer_orders": {
      ".read": false,
      ".write": false,
      "$emailHash": {
        ".read": "auth != null",
        ".write": true
      }
    },

    "custom_orders": {
      ".read": "auth != null",
      ".write": true
    },

    "sticker_orders": {
      ".read": "auth != null",
      ".write": true
    },

    "sticker_purchases": {
      ".read": "auth != null",
      ".write": true
    },

    "inquiries": {
      ".read": "auth != null",
      ".write": true
    },

    "pendingCarts": {
      ".read": "auth != null",
      ".write": true
    },

    "customers": {
      ".read": "auth != null",
      ".write": true
    },

    "adminNotifications": {
      ".read": "auth != null",
      ".write": true
    },

    "products": {
      ".read": true,
      ".write": "auth != null"
    },

    "collections": {
      ".read": true,
      ".write": "auth != null"
    },

    "promotions": {
      ".read": true,
      ".write": "auth != null"
    },

    "reviews": {
      ".read": true,
      ".write": "auth != null",
      "$reviewId": {
        ".write": "auth != null || (!data.exists() && newData.exists() && newData.child('status').val() === 'pending')"
      }
    },

    "announcements": {
      ".read": true,
      ".write": "auth != null"
    },

    "stickers": {
      ".read": true,
      ".write": "auth != null"
    },

    "brands": {
      ".read": true,
      ".write": "auth != null"
    },

    "inventory": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "payment_settings": {
      ".read": true,
      ".write": "auth != null"
    },

    "admins": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "admin_login_enabled": {
      ".read": true,
      ".write": "auth != null"
    },

    "visitors": {
      ".read": "auth != null",
      ".write": true
    }
  }
}
